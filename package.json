{
  "name": "contrail",
  "version": "0.0.0",
  "private": true,
  "description": "Contrail — A vapor trail for what an AI knows about you",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukitadproxd-netizen/contrail.git"
  },
  "license": "Apache-2.0",
  "author": "Contrail Contributors",
  "homepage": "https://lukitadproxd-netizen.github.io/contrail",
  "bugs": {
    "url": "https://github.com/lukitadproxd-netizen/contrail/issues"
  },
  "keywords": [
    "ai-memory",
    "mcp",
    "interoperability",
    "json-schema",
    "temporal",
    "confidence"
  ],
  "workspaces": [
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:engram && npm run build:cli && npm run build:mcp",
    "build:core": "npm run build --workspace=@lukitadproxd-netizen/core --if-present",
    "build:engram": "npm run build --workspace=@lukitadproxd-netizen/engram --if-present",
    "build:cli": "npm run build --workspace=@lukitadproxd-netizen/cli --if-present",
    "build:mcp": "npm run build --workspace=@lukitadproxd-netizen/mcp --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test --workspace=@lukitadproxd-netizen/core --if-present",
    "test:cli": "npm run test --workspace=@lukitadproxd-netizen/cli --if-present",
    "test:mcp": "npm run test --workspace=@lukitadproxd-netizen/mcp --if-present",
    "test:engram": "npm run test --workspace=@lukitadproxd-netizen/engram --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate:spec": "node scripts/validate-examples.js",
    "dev": "npm run dev --workspaces --if-present",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.12.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0",
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  }
}
